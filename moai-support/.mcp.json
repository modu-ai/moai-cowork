{
  "mcpServers": {
    "slack": {
      "type": "http",
      "url": "https://mcp.slack.com/sse",
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
        "SLACK_TEAM_ID": "${SLACK_TEAM_ID}"
      }
    },
    "notion": {
      "type": "http",
      "url": "https://mcp.notion.so/mcp",
      "env": {
        "NOTION_API_KEY": "${NOTION_API_KEY}"
      }
    }
  }
}
